# AI Eraser — Environment Configuration
# Copy this file to .env and fill in your values.

# =============================================================================
# REQUIRED
# =============================================================================

# Anthropic API key for Claude AI integration
ANTHROPIC_API_KEY=sk-ant-your-key-here

# =============================================================================
# OPTIONAL — Email (for sending removal requests)
# =============================================================================

# SMTP — for sending removal emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# IMAP — for inbox monitoring (auto-detect broker responses)
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=
IMAP_PASS=

# =============================================================================
# OPTIONAL — Overrides (defaults are fine for most users)
# =============================================================================

# Claude model (default: claude-sonnet-4-20250514)
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Firecrawl API key for enhanced web scraping during research
# FIRECRAWL_API_KEY=

# Dashboard port (default: 3847)
# DASHBOARD_PORT=3847

# Dashboard bind address (default: 127.0.0.1, use 0.0.0.0 for Docker)
# DASHBOARD_HOST=127.0.0.1

# Database path (default: data/ai-eraser.db)
# DB_PATH=data/ai-eraser.db

# Vault data directory (default: data/vault)
# VAULT_DATA_DIR=data/vault

# Log level: debug | info | warn | error (default: info)
# LOG_LEVEL=info

# Enable background scheduler (default: false)
# SCHEDULER_ENABLED=false
